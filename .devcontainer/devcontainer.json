{
  "forwardPorts": [3000],
  "build": {"dockerfile": "Dockerfile"},
  "onCreateCommand": "bash .devcontainer/setup.sh",
  "postAttachCommand": "bash .devcontainer/run-server.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "remote.autoForwardPorts": false
      },
      "extensions": [
        "leanprover.lean4"
      ]
    },
    "codespaces": {
      "openFiles": ["Game.lean"]
    }
  }
}
